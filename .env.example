# Copy to .env for local dev. On balena, set these as fleet/device variables instead.
TZ=UTC                  # your timezone, e.g. America/New_York or Europe/London

# --- Receiver location (fallback if no GPS fix). Decimal degrees + altitude. ---
RECEIVER_LAT=0.0
RECEIVER_LON=0.0
RECEIVER_ALT=20m

# --- Decode source for the app (ultrafeeder/tar1090 aircraft.json) ---
AIRCRAFT_JSON_URL=http://ultrafeeder/data/aircraft.json
POLL_SECONDS=1

# --- Route enrichment backend: adsbdb | adsblol ---
ROUTE_API=adsbdb

# --- LED matrix geometry (e.g. two 64x32 panels chained = 128x32 ticker) ---
MATRIX_ROWS=32
MATRIX_COLS=64
MATRIX_CHAIN=1            # one 64x32 panel (set 2 if you add a second -> 128x32 ticker)
MATRIX_PARALLEL=1
MATRIX_BRIGHTNESS=60
# Driver: hzeller rpi-rgb-led-matrix. On the Pi 5 it uses the PIO backend (rp1_pio=1, via
# /dev/pio0 — needs a recent Pi 5 EEPROM); set MATRIX_RP1_PIO=0 to fall back to the RIO
# (/dev/mem) backend. Bonnet hardware mapping = "adafruit-hat".
MATRIX_HARDWARE=adafruit-hat
MATRIX_RP1_PIO=1
MATRIX_GPIO_SLOWDOWN=2

# --- App <-> display link ---
APP_WS_URL=ws://app:8080/ws
